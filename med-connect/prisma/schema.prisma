generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {

  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  image         String?
  role          Role           @default(PATIENT)
  createdAt     DateTime       @default(now())
  password      String?
  symptomChecks SymptomCheck[]
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  doctor        Doctor?
  patient       Patient?


}

model Doctor {
  id             String        @id @default(cuid())
  userId         String        @unique
  specialization String
  qualifications String
  experience     Int
  fee            Int
  bio            String?
  rating         Float         @default(0)
  isAvailable    Boolean       @default(true)
  appointments   Appointment[]
  user           User          @relation(fields: [userId], references: [id])
  availableSlots Slot[]
  prescriptions  Prescription[]
}

model Patient {
  id                          String        @id @default(cuid())
  userId                      String        @unique
  fullName                    String?
  dateOfBirth                 DateTime?
  bloodGroup                  String?
  gender                      String?
  allergies                   String[]
  medicalHistory              String?
  emergencyContactName        String?
  emergencyContactRelationship String?
  emergencyContactPhone       String?
  appointments                Appointment[]
  prescriptions               Prescription[]
  user                        User          @relation(fields: [userId], references: [id])
}

model Appointment {
  id           String     @id @default(cuid())
  doctorId     String
  patientId    String
  date         DateTime
  timeSlot     String
  status       ApptStatus @default(PENDING)
  type         ApptType   @default(VIDEO)
  symptoms     String?
  prescription String?
  notes        String?
  createdAt    DateTime   @default(now())
  doctor       Doctor     @relation(fields: [doctorId], references: [id])
  patient      Patient    @relation(fields: [patientId], references: [id])
}

model Slot {
  id        String    @id @default(cuid())
  doctorId  String
  day       DayOfWeek
  startTime String
  endTime   String
  isBooked  Boolean   @default(false)
  doctor    Doctor    @relation(fields: [doctorId], references: [id])
}


model SymptomCheck {
  id        String   @id @default(cuid())
  userId    String
  symptom   String
  advice    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum ApptStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ApptType {
  VIDEO
  IN_PERSON
  PHONE
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}
model Prescription {
  id            String   @id @default(cuid())
  doctorId      String
  patientId     String
  medication    String
  dosage        String
  frequency     String
  duration      String
  refills       Int      @default(0)
  instructions  String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  doctor        Doctor   @relation(fields: [doctorId], references: [id])
  patient       Patient  @relation(fields: [patientId], references: [id])
}
